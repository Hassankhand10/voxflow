generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

enum FlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  VIDEO
  AUDIO
  TEXT
  RATING
  FILE
  MULTIPLE_CHOICE
  DATE
  EMAIL
  PHONE
  SIGNATURE
}

enum ResponseStatus {
  IN_PROGRESS
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  NEW_RESPONSE
  MENTION
  AI_FINISHED
  FLOW_SHARED
  STORAGE_WARNING
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String
  avatarUrl    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  responses    Response[]
  comments     Comment[]
  notifications Notification[]
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  flows     Flow[]
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  role        MemberRole @default(VIEWER)
  userId      String
  workspaceId String
  joinedAt    DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Flow {
  id              String     @id @default(cuid())
  name            String
  description     String?
  slug            String     @unique
  status          FlowStatus @default(DRAFT)
  requireEmail    Boolean    @default(true)
  allowRetakes    Boolean    @default(true)
  passwordProtected Boolean  @default(false)
  password        String?
  workspaceId     String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  questions       Question[]
  responses       Response[]

  @@index([workspaceId])
  @@index([slug])
}

model Question {
  id          String       @id @default(cuid())
  title       String
  type        QuestionType @default(VIDEO)
  order       Int
  timeLimit   Int?
  required    Boolean      @default(true)
  aiFollowUp  Boolean      @default(false)
  placeholder String?
  options     String[]     @default([])
  mediaUrl    String?
  mediaType   String?
  isThankYou  Boolean      @default(false)
  flowId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  flow        Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  answers     Answer[]

  @@index([flowId, order])
}

model Response {
  id              String         @id @default(cuid())
  flowId          String
  respondentName  String
  respondentEmail String
  status          ResponseStatus @default(IN_PROGRESS)
  duration        Int            @default(0)
  transcript      String?
  aiSummary       String?
  aiTags          String[]       @default([])
  aiScore         Int?
  notes           String?
  submittedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  flow            Flow           @relation(fields: [flowId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers         Answer[]
  comments        Comment[]

  @@index([flowId])
  @@index([status])
}

model Answer {
  id              String   @id @default(cuid())
  responseId      String
  questionId      String
  textValue       String?
  fileUrl         String?
  fileType        String?
  duration        Int?
  aiFollowUpText  String?
  aiFollowUpAnswer String?
  createdAt       DateTime @default(now())
  response        Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  responseId String
  userId     String
  createdAt  DateTime @default(now())
  response   Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  userId    String
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String
  questions   Json
  createdAt   DateTime @default(now())
}
